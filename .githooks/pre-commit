#!/bin/sh
# Style feedback on staged files only — fast. Heavier checks (Brakeman,
# bundler-audit) live in the pre-push hook.
status=0

ruby_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(rb|rake|builder)$|(^|/)Gemfile$')
[ -n "$ruby_files" ] && { bin/rubocop --force-exclusion $ruby_files || status=1; }

erb_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.erb$')
[ -n "$erb_files" ] && { bin/erb_lint $erb_files || status=1; }

exit $status
