<div id="loginpage">
  <%= image_tag "/images/brueschhuesli.png", title: "brueschhuesli", class: "welcomepicture" %>
  <fieldset>
    <legend>Bitte einloggen</legend>
    <%= form_with url: session_path do |form| %>
      <table class="reservation-detail">
        <tr>
          <td class="legend">Name:</td>
          <td class="data"><%= text_field_tag :name, params[:name], autocomplete: "username" %></td>
        </tr>
        <tr>
          <td class="legend">Passwort:</td>
          <td class="data"><%= password_field_tag :password, params[:password], autocomplete: "current-password" %></td>
        </tr>
      </table>
      <%= submit_tag "Login" %>
    <% end %>
  </fieldset>
</div>
