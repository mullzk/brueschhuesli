<div class="page-row">
   <div class="month-navigation">
  <p><%= link_to ">#{l(@months.first.first_of_month - 1.month, format: :month_year)}", { controller: "reservations", action: "index", date: (@months.first.first_of_month - 1.month) } -%></p>
  <p><%= link_to ">#{l(@months.first.first_of_month + 1.month, format: :month_year)}", { controller: "reservations", action: "index", date: (@months.first.first_of_month + 1.month) } -%></p>
  </div>
</div>

<div class="page-row" id="reservationskalender">
  <%= render partial: "month", collection: @months, as: :month %>
</div>

<div class="month-navigation-js">
  <p><%= link_to "", { controller: "reservations", action: "month", date: (@months.first.first_of_month - 1.month) }, "data-loading-preceding-month-link" => "false" -%></p>
  <p><%= link_to "", { controller: "reservations", action: "month", date: (@months.last.first_of_month + 1.month) }, "data-loading-succeeding-month-link" => "false" -%></p>
</div>

<div id="loadinghint">loading...</div>
