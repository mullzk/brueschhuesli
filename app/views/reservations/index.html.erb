<div data-controller="calendar" data-action="scroll@window->calendar#onScroll">
  <div class="cal-toolbar">
    <%= link_to "‹ Früher", { controller: "reservations", action: "index", date: (@months.first.first_of_month - 1.month) }, class: "cal-toolbar__btn", data: { action: "click->calendar#earlier" } -%>
    <button type="button" class="cal-toolbar__btn cal-toolbar__today" data-calendar-target="today" data-action="click->calendar#today" hidden>Heute</button>
  </div>

  <div class="page-row" id="reservationskalender" data-calendar-target="months">
    <%= render partial: "month", collection: @months, as: :month %>
  </div>

  <div id="loadinghint" data-calendar-target="hint">lädt …</div>
</div>

<div class="overlay" data-controller="overlay" data-action="keydown@window->overlay#closeOnEscape click->overlay#closeOnBackdrop" hidden>
  <%= turbo_frame_tag "modal", class: "overlay__sheet", data: { overlay_target: "frame" } %>
</div>
