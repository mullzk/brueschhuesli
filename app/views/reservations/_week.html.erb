<div class="calendar__week">
  <div class="calendar__cells">
    <% week.days.each do |day| %>
      <% if day.in_month? %>
        <% modifier = day.free? ? "free" : "occupied" %>
        <% target = day.free? ? url_for(controller: "reservations", action: "new", date: day.date) : url_for(controller: "reservations", action: "on_day", date: day.date) %>
        <div class="calendar__cell calendar__cell--<%= modifier %><%= " calendar__cell--today" if day.today? %>"
             data-controller="enter-href" data-enter-href-url-value="<%= target %>">
          <span class="calendar__num"><%= day.date.day %></span>
        </div>
      <% else %>
        <div class="calendar__cell calendar__cell--out">
          <span class="calendar__num"><%= day.date.day %></span>
        </div>
      <% end %>
    <% end %>
  </div>
  <% if week.segments.any? %>
    <div class="calendar__bars">
      <% week.segments.each do |segment| %>
        <div class="calendar__bar calendar__bar--<%= segment.exclusive? ? "exclusive" : "open" %><%= " calendar__bar--narrow" if segment.single_column? %><%= " calendar__bar--day" if segment.single_day? %><%= " calendar__bar--cont-l" if segment.continues_left? %><%= " calendar__bar--cont-r" if segment.continues_right? %>"
             style="grid-column: <%= segment.start_col %> / <%= segment.end_col + 1 %>; grid-row: <%= segment.lane + 1 %>;">
          <span class="calendar__bar-name"><%= segment.reservation.user.name %></span>
          <% if segment.single_day? %>
            <span class="calendar__bar-time"><%= segment.reservation.start.strftime("%H:%M") %>–<%= segment.reservation.finish.strftime("%H:%M") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
